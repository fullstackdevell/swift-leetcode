class Solution {
    func findNumbers(_ nums: [Int]) -> Int {
        var evenNumbers = 0

        for num in nums {
            var number = num
            var digitCount = 0

            while number > 0 {
                number = number / 10
                digitCount += 1
            }
            if digitCount % 2 == 0 {
                evenNumbers += 1
            }
        }
        return evenNumbers
    }
}
